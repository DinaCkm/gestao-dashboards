  "query": "\nSELECT ac.microInicio, ac.microTermino, COUNT(*) as cnt, COUNT(DISTINCT ap.alunoId) as alunos, GROUP_CONCAT(DISTINCT ap.alunoId) as aluno_ids\nFROM assessment_competencias ac\nJOIN assessment_pdi ap ON ac.assessmentPdiId = ap.id\nJOIN trilhas t ON ap.trilhaId = t.id\nWHERE t.name LIKE '%Vis%'\nGROUP BY ac.microInicio, ac.microTermino\nORDER BY ac.microInicio;\n",
