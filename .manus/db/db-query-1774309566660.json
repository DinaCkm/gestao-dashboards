  "query": "\nSELECT \n  ms.id AS sessao_id,\n  ms.sessionDate,\n  ms.sessionNumber,\n  ms.presence,\n  ms.isAssessment,\n  ms.alunoId,\n  a.name AS aluno_nome,\n  ms.consultorId,\n  c.name AS mentor_nome,\n  p.name AS empresa_nome\nFROM mentoring_sessions ms\nLEFT JOIN alunos a ON ms.alunoId = a.id\nLEFT JOIN consultors c ON ms.consultorId = c.id\nLEFT JOIN programs p ON a.programId = p.id\nWHERE ms.sessionDate >= '2026-03-01' AND ms.sessionDate <= '2026-03-31'\nORDER BY ms.sessionDate, ms.consultorId, ms.alunoId;\n",
